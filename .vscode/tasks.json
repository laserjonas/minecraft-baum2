{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Minecraft Client",
      "type": "shell",
      "command": "./gradlew.bat runClient",
      "windows": {
        "command": ".\\gradlew.bat runClient"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Minecraft Server",
      "type": "shell",
      "command": "./gradlew.bat runServer",
      "windows": {
        "command": ".\\gradlew.bat runServer"
      },
      "problemMatcher": []
    },
    {
