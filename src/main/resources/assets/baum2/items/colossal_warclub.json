{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "baum2:weapon_tier",
    "cases": [
      {
        "when": "tempered",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:display_context",
          "cases": [
            {
              "when": ["gui", "ground", "fixed", "on_shelf"],
              "model": { "type": "minecraft:model", "model": "baum2:item/colossal_warclub_tempered" }
            }
          ],
          "fallback": { "type": "minecraft:model", "model": "baum2:item/colossal_warclub_in_hand_tempered" }
        }
      },
      {
        "when": "perfect",
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:display_context",
          "cases": [
            {
              "when": ["gui", "ground", "fixed", "on_shelf"],
              "model": { "type": "minecraft:model", "model": "baum2:item/colossal_warclub_perfect" }
            }
          ],
          "fallback": { "type": "minecraft:model", "model": "baum2:item/colossal_warclub_in_hand_perfect" }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:display_context",
      "cases": [
        {
          "when": ["gui", "ground", "fixed", "on_shelf"],
          "model": { "type": "minecraft:model", "model": "baum2:item/colossal_warclub" }
        }
      ],
      "fallback": { "type": "minecraft:model", "model": "baum2:item/colossal_warclub_in_hand" }
    }
  }
}
